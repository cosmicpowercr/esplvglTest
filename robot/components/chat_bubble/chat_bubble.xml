<!--
    Chat Bubble Component
    Used in AI dialog mode to display conversation messages.
    - User messages: right-aligned, blue (#2E7DF6) background
    - AI messages: left-aligned, dark (#2A333F) background
    - role prop: "user" or "ai" determines alignment and colors
-->
<component>
    <previews>
        <preview width="240" height="60" style_pad_all="8" />
    </previews>

    <api>
        <prop name="role" type="string" default="ai" help="user or ai" />
        <prop name="message" type="string" default="Hello!" help="The message text" />
    </api>

    <styles>
        <!-- User bubble style (right-aligned, blue) -->
        <style name="style_user_bubble"
            bg_color="#bg_bubble_user" bg_opa="100%"
            text_color="#FFFFFF"
            radius="#unit_md"
            pad_hor="#unit_md"
            pad_ver="#unit_sm"
            width="content"
            max_width="180"
            height="content"
            text_font="font_12"
        />

        <!-- AI bubble style (left-aligned, dark gray) -->
        <style name="style_ai_bubble"
            bg_color="#bg_bubble_ai" bg_opa="100%"
            text_color="#FFFFFF"
            radius="#unit_md"
            pad_hor="#unit_md"
            pad_ver="#unit_sm"
            width="content"
            max_width="180"
            height="content"
            text_font="font_12"
        />
    </styles>

    <view width="100%" height="content" style_pad_ver="#unit_xs">
        <!-- AI message: left-aligned -->
        <lv_label
            text="$message"
            align="left"
        >
            <style name="style_ai_bubble" />
        </lv_label>

        <!-- User message: right-aligned -->
        <lv_label
            text="$message"
            align="right"
        >
            <style name="style_user_bubble" />
        </lv_label>
    </view>
</component>
