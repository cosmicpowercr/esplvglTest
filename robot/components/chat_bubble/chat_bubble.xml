<!--
    Chat Bubble Component
    Used in AI dialog mode to display conversation messages.
    - User messages: right-aligned, blue background
    - AI messages: left-aligned, gray background
    - role prop: "user" or "ai" determines alignment and colors
-->
<component>
    <previews>
        <preview width="240" height="60" style_pad_all="8" />
    </previews>

    <api>
        <prop name="role" type="string" default="ai" help="user or ai" />
        <prop name="message" type="string" default="Hello!" help="The message text" />
    </api>

    <styles>
        <!-- User bubble style (right-aligned, blue) -->
        <style name="style_user_bubble"
            bg_color="0x3b82f6"
            bg_opa="100%"
            text_color="0xffffff"
            radius="#unit_md"
            pad_hor="#unit_md"
            pad_ver="#unit_sm"
            width="content"
            max_width="180"
            height="content"
        />

        <!-- AI bubble style (left-aligned, gray) -->
        <style name="style_ai_bubble"
            bg_color="0xe5e7eb"
            bg_opa="100%"
            text_color="0x1f2937"
            radius="#unit_md"
            pad_hor="#unit_md"
            pad_ver="#unit_sm"
            width="content"
            max_width="180"
            height="content"
        />
        <style name="style_ai_bubble_dark"
            bg_color="0x374151"
            text_color="0xf9fafb"
        />
    </styles>

    <view width="100%" height="content" style_pad_ver="#unit_xs">
        <!-- AI message: left-aligned -->
        <lv_label
            text="$message"
            style_text_font="font_12"
            align="left"
        >
            <style name="style_ai_bubble" />
            <bind_style name="style_ai_bubble_dark" subject="dark_theme" ref_value="1" />
            <!-- Hide when role is user -->
        </lv_label>
    </view>
</component>
