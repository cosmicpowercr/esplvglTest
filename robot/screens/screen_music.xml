<!--
    Local Music Page
    ================
    Displays MP3 files from the SD card in a scrollable list.
    - No progress bar, no prev/next buttons
    - Highlight-selection: tap or scroll-and-stop to select a song for playback
    - Scroll-stop-3s: after scrolling stops for 3 seconds, the highlighted
      song is selected and begins playing (logic handled by C code)

    Controls:
      - Sort Order button: toggle between Sequential (by filename) and Random
      - Play Mode button: toggle between Single Repeat and List Play

    LVGL Symbol Reference:
      - LV_SYMBOL_LIST (sequential) ↔ LV_SYMBOL_SHUFFLE (random)
      - LV_SYMBOL_LOOP (single repeat) ↔ LV_SYMBOL_REFRESH (list play)
-->
<screen>
    <styles>
        <!-- Top navigation bar -->
        <style name="style_top_bar"
            bg_color="0xffffff"
            bg_opa="100%"
            width="100%"
            height="36"
            pad_hor="#unit_md"
        />
        <style name="style_top_bar_dark"
            bg_color="0x16213e"
        />

        <!-- Back button -->
        <style name="style_back_btn"
            bg_opa="0%"
            radius="1000"
            pad_all="#unit_sm"
            width="32"
            height="32"
            text_color="0x9ca3af"
            text_font="font_16"
        />
        <style name="style_back_btn_dark"
            text_color="0xd1d5db"
        />

        <!-- Title style -->
        <style name="style_page_title"
            text_font="font_16"
            text_color="0x374151"
        />
        <style name="style_page_title_dark"
            text_color="0xf9fafb"
        />

        <!-- Control bar (sort + play mode buttons) -->
        <style name="style_control_bar"
            bg_color="0xffffff"
            bg_opa="100%"
            width="100%"
            height="40"
            pad_hor="#unit_md"
        />
        <style name="style_control_bar_dark"
            bg_color="0x16213e"
        />

        <!-- Control button -->
        <style name="style_control_btn"
            bg_color="0xf1f5f9"
            bg_opa="100%"
            radius="1000"
            pad_hor="#unit_md"
            pad_ver="4"
            width="content"
            height="30"
            border_color="0xe2e8f0"
            border_width="1"
        />
        <style name="style_control_btn_dark"
            bg_color="0x1e293b"
            border_color="0x334155"
        />

        <!-- Control button text -->
        <style name="style_control_text"
            text_font="font_10"
            text_color="0x475569"
        />
        <style name="style_control_text_dark"
            text_color="0xe2e8f0"
        />

        <!-- Control button icon -->
        <style name="style_control_icon"
            text_font="font_14"
            text_color="0x475569"
        />
        <style name="style_control_icon_dark"
            text_color="0xe2e8f0"
        />

        <!-- Currently playing info bar -->
        <style name="style_now_playing_bar"
            bg_color="0xeff6ff"
            bg_opa="100%"
            width="100%"
            pad_hor="#unit_md"
            pad_ver="#unit_sm"
            radius="#unit_sm"
        />
        <style name="style_now_playing_bar_dark"
            bg_color="0x1e3a5f"
        />

        <style name="style_now_playing_text"
            text_font="font_10"
            text_color="0x3b82f6"
        />
        <style name="style_now_playing_text_dark"
            text_color="0x93c5fd"
        />

        <!-- Song list scroll area -->
        <style name="style_list_bg"
            bg_color="0xf5f5f5"
            bg_opa="100%"
            width="100%"
            pad_hor="#unit_sm"
            pad_ver="#unit_xs"
        />
        <style name="style_list_bg_dark"
            bg_color="0x1a1a2e"
        />

        <!-- Song item (normal) -->
        <style name="style_song_item"
            bg_color="0xffffff"
            bg_opa="100%"
            width="100%"
            height="content"
            pad_hor="#unit_md"
            pad_ver="#unit_sm"
            radius="#unit_sm"
            shadow_width="2"
            shadow_offset_y="1"
            shadow_opa="8%"
        />
        <style name="style_song_item_dark"
            bg_color="0x1e293b"
            shadow_opa="15%"
        />

        <!-- Song item (selected/highlighted) -->
        <style name="style_song_item_selected"
            bg_color="0xdbeafe"
            bg_opa="100%"
            border_color="0x3b82f6"
            border_width="2"
            border_opa="100%"
        />
        <style name="style_song_item_selected_dark"
            bg_color="0x1e3a5f"
            border_color="0x60a5fa"
        />

        <!-- Song name text -->
        <style name="style_song_name"
            text_font="font_12"
            text_color="0x1f2937"
        />
        <style name="style_song_name_dark"
            text_color="0xf9fafb"
        />

        <!-- Playing indicator -->
        <style name="style_playing_indicator"
            text_font="font_10"
            text_color="0x3b82f6"
        />
        <style name="style_playing_indicator_dark"
            text_color="0x60a5fa"
        />

        <!-- Empty state -->
        <style name="style_empty_text"
            text_font="font_14"
            text_color="0x9ca3af"
            text_align="center"
        />
        <style name="style_empty_text_dark"
            text_color="0x6b7280"
        />
    </styles>

    <view flex_flow="column" width="100%" height="100%">
        <!-- Screen background -->
        <style name="style_screen_light" />
        <bind_style name="style_screen_dark" subject="dark_theme" ref_value="1" />

        <!-- ====== Top Navigation Bar ====== -->
        <lv_obj flex_flow="row" width="100%" style_flex_main_place="start" style_flex_cross_place="center">
            <style name="style_top_bar" />
            <bind_style name="style_top_bar_dark" subject="dark_theme" ref_value="1" />

            <!-- Back button -->
            <lv_button>
                <style name="style_back_btn" />
                <bind_style name="style_back_btn_dark" subject="dark_theme" ref_value="1" />
                <lv_label text="←" style_text_font="font_16" style_text_color="0x9ca3af" />
                <screen_load_event screen="screen_ai_main" anim_type="move_right" duration="300" />
            </lv_button>

            <lv_label text="Local Music" style_pad_left="#unit_sm">
                <style name="style_page_title" />
                <bind_style name="style_page_title_dark" subject="dark_theme" ref_value="1" />
            </lv_label>
        </lv_obj>

        <!-- ====== Control Bar: Sort Order + Play Mode ====== -->
        <lv_obj flex_flow="row" width="100%" style_flex_main_place="space_between" style_flex_cross_place="center">
            <style name="style_control_bar" />
            <bind_style name="style_control_bar_dark" subject="dark_theme" ref_value="1" />

            <!-- Sort Order Button -->
            <!-- sort_order: 0=Sequential (by filename), 1=Random -->
            <lv_button name="sort_order_btn">
                <style name="style_control_btn" />
                <bind_style name="style_control_btn_dark" subject="dark_theme" ref_value="1" />

                <lv_obj flex_flow="row" style_flex_cross_place="center" style_pad_column="#unit_xs">
                    <!-- Sequential icon (LV_SYMBOL_LIST) - shown when sort_order=0 -->
                    <lv_label text="📋">
                        <style name="style_control_icon" />
                        <bind_style name="style_control_icon_dark" subject="dark_theme" ref_value="1" />
                        <bind_flag_if_eq subject="sort_order" ref_value="1" flag="hidden" />
                    </lv_label>
                    <!-- Random icon (LV_SYMBOL_SHUFFLE) - shown when sort_order=1 -->
                    <lv_label text="🔀">
                        <style name="style_control_icon" />
                        <bind_style name="style_control_icon_dark" subject="dark_theme" ref_value="1" />
                        <bind_flag_if_eq subject="sort_order" ref_value="0" flag="hidden" />
                    </lv_label>
                    <!-- Label -->
                    <lv_label text="Seq" style_text_font="font_10" style_text_color="0x374151">
                        <bind_style name="style_control_text_dark" subject="dark_theme" ref_value="1" />
                        <bind_flag_if_eq subject="sort_order" ref_value="1" flag="hidden" />
                    </lv_label>
                    <lv_label text="Rand" style_text_font="font_10" style_text_color="0x374151">
                        <bind_style name="style_control_text_dark" subject="dark_theme" ref_value="1" />
                        <bind_flag_if_eq subject="sort_order" ref_value="0" flag="hidden" />
                    </lv_label>
                </lv_obj>

                <!-- Click toggles sort_order between 0 and 1 -->
                <!-- C code: handle the toggle logic -->
                <subject_set_int_event subject="sort_order" value="1" trigger="clicked" />
            </lv_button>

            <!-- Play Mode Button -->
            <!-- play_mode: 0=Single Repeat (loop one song), 1=List Play (play through list) -->
            <lv_button name="play_mode_btn">
                <style name="style_control_btn" />
                <bind_style name="style_control_btn_dark" subject="dark_theme" ref_value="1" />

                <lv_obj flex_flow="row" style_flex_cross_place="center" style_pad_column="#unit_xs">
                    <!-- Single Repeat icon (LV_SYMBOL_LOOP) - shown when play_mode=0 -->
                    <lv_label text="🔂">
                        <style name="style_control_icon" />
                        <bind_style name="style_control_icon_dark" subject="dark_theme" ref_value="1" />
                        <bind_flag_if_eq subject="play_mode" ref_value="1" flag="hidden" />
                    </lv_label>
                    <!-- List Play icon (LV_SYMBOL_REFRESH) - shown when play_mode=1 -->
                    <lv_label text="🔁">
                        <style name="style_control_icon" />
                        <bind_style name="style_control_icon_dark" subject="dark_theme" ref_value="1" />
                        <bind_flag_if_eq subject="play_mode" ref_value="0" flag="hidden" />
                    </lv_label>
                    <!-- Label -->
                    <lv_label text="Single" style_text_font="font_10" style_text_color="0x374151">
                        <bind_style name="style_control_text_dark" subject="dark_theme" ref_value="1" />
                        <bind_flag_if_eq subject="play_mode" ref_value="1" flag="hidden" />
                    </lv_label>
                    <lv_label text="List" style_text_font="font_10" style_text_color="0x374151">
                        <bind_style name="style_control_text_dark" subject="dark_theme" ref_value="1" />
                        <bind_flag_if_eq subject="play_mode" ref_value="0" flag="hidden" />
                    </lv_label>
                </lv_obj>

                <!-- Click toggles play_mode between 0 and 1 -->
                <subject_set_int_event subject="play_mode" value="1" trigger="clicked" />
            </lv_button>
        </lv_obj>

        <!-- ====== Now Playing Indicator ====== -->
        <lv_obj name="now_playing_bar" flex_flow="row" width="100%" style_flex_cross_place="center" style_pad_column="#unit_sm">
            <style name="style_now_playing_bar" />
            <bind_style name="style_now_playing_bar_dark" subject="dark_theme" ref_value="1" />

            <lv_label text="♪">
                <style name="style_playing_indicator" />
                <bind_style name="style_playing_indicator_dark" subject="dark_theme" ref_value="1" />
            </lv_label>
            <lv_label bind_text="current_song_name" style_text_font="font_10">
                <style name="style_now_playing_text" />
                <bind_style name="style_now_playing_text_dark" subject="dark_theme" ref_value="1" />
            </lv_label>
        </lv_obj>

        <!-- ====== Scrollable Song List ====== -->
        <!--
            C code dynamically creates song items as children of this container.
            Each item shows the MP3 file name. The currently selected item is
            highlighted with style_song_item_selected.

            Scroll-stop detection (3s delay before auto-play):
            - C code monitors scroll events on this container
            - When scrolling stops, start a 3-second timer
            - When timer fires: determine which item is at the scroll position,
              set current_song_index, highlight it, and start playback
            - If user scrolls again before 3s, reset the timer

            Dynamic item creation example (for C code reference):
            For each song file found on SD card:
                lv_obj_t *item = lv_obj_create(song_list_container);
                lv_obj_set_size(item, LV_PCT(100), LV_SIZE_CONTENT);
                lv_obj_add_style(item, &style_song_item, 0);
                lv_obj_t *label = lv_label_create(item);
                lv_label_set_text(label, filename);
        -->
        <lv_obj
            name="song_list_container"
            flex_grow="1"
            flex_flow="column"
            scrollable="true"
            style_pad_row="#unit_xs"
        >
            <style name="style_list_bg" />
            <bind_style name="style_list_bg_dark" subject="dark_theme" ref_value="1" />

            <!-- Empty state (shown when no songs found) -->
            <!-- C code: show/hide based on song_count subject -->
            <lv_label
                name="song_list_empty"
                text="No MP3 files found&#10;on SD card"
                width="100%"
                align="center"
                y="60"
            >
                <style name="style_empty_text" />
                <bind_style name="style_empty_text_dark" subject="dark_theme" ref_value="1" />
            </lv_label>

            <!-- ====== Placeholder Song Items (for LVGL Pro preview) ====== -->
            <!-- These are statically defined for the editor preview.
                 At runtime, C code removes these and creates items dynamically
                 based on actual SD card contents. -->

            <!-- Song 1 (selected/playing) -->
            <lv_obj name="song_item_0" flex_flow="row" width="100%" style_flex_main_place="space_between" style_flex_cross_place="center">
                <style name="style_song_item" />
                <style name="style_song_item_selected" />
                <bind_style name="style_song_item_dark" subject="dark_theme" ref_value="1" />
                <lv_label text="01_sunrise_melody.mp3">
                    <style name="style_song_name" />
                    <bind_style name="style_song_name_dark" subject="dark_theme" ref_value="1" />
                </lv_label>
                <lv_label text="▶">
                    <style name="style_playing_indicator" />
                    <bind_style name="style_playing_indicator_dark" subject="dark_theme" ref_value="1" />
                </lv_label>
            </lv_obj>

            <!-- Song 2 -->
            <lv_obj name="song_item_1" flex_flow="row" width="100%" style_flex_main_place="space_between" style_flex_cross_place="center">
                <style name="style_song_item" />
                <bind_style name="style_song_item_dark" subject="dark_theme" ref_value="1" />
                <lv_label text="02_ocean_waves.mp3">
                    <style name="style_song_name" />
                    <bind_style name="style_song_name_dark" subject="dark_theme" ref_value="1" />
                </lv_label>
            </lv_obj>

            <!-- Song 3 -->
            <lv_obj name="song_item_2" flex_flow="row" width="100%" style_flex_main_place="space_between" style_flex_cross_place="center">
                <style name="style_song_item" />
                <bind_style name="style_song_item_dark" subject="dark_theme" ref_value="1" />
                <lv_label text="03_forest_rain.mp3">
                    <style name="style_song_name" />
                    <bind_style name="style_song_name_dark" subject="dark_theme" ref_value="1" />
                </lv_label>
            </lv_obj>

            <!-- Song 4 -->
            <lv_obj name="song_item_3" flex_flow="row" width="100%" style_flex_main_place="space_between" style_flex_cross_place="center">
                <style name="style_song_item" />
                <bind_style name="style_song_item_dark" subject="dark_theme" ref_value="1" />
                <lv_label text="04_jazz_cafe.mp3">
                    <style name="style_song_name" />
                    <bind_style name="style_song_name_dark" subject="dark_theme" ref_value="1" />
                </lv_label>
            </lv_obj>

            <!-- Song 5 -->
            <lv_obj name="song_item_4" flex_flow="row" width="100%" style_flex_main_place="space_between" style_flex_cross_place="center">
                <style name="style_song_item" />
                <bind_style name="style_song_item_dark" subject="dark_theme" ref_value="1" />
                <lv_label text="05_deep_focus.mp3">
                    <style name="style_song_name" />
                    <bind_style name="style_song_name_dark" subject="dark_theme" ref_value="1" />
                </lv_label>
            </lv_obj>

            <!-- Song 6 -->
            <lv_obj name="song_item_5" flex_flow="row" width="100%" style_flex_main_place="space_between" style_flex_cross_place="center">
                <style name="style_song_item" />
                <bind_style name="style_song_item_dark" subject="dark_theme" ref_value="1" />
                <lv_label text="06_night_drive.mp3">
                    <style name="style_song_name" />
                    <bind_style name="style_song_name_dark" subject="dark_theme" ref_value="1" />
                </lv_label>
            </lv_obj>

        </lv_obj>
    </view>
</screen>
