<!--
    AI Main Page (Permanent Screen)
    ================================
    This screen is permanent — it is created once and never deleted, so all
    widget states persist across page switches. The mode (expression or dialog)
    is controlled by the "ai_mode" subject. Mode switching happens in the
    Settings page; when ai_mode changes, the C code resets this screen.

    Modes:
      ai_mode = 0: Expression Mode — animated face that reacts to conversation
      ai_mode = 1: Dialog Mode — WeChat-style chat history (last 25 messages)

    References:
      - Expression mode inspired by EchoEar (esp-brookesia speaker product)
      - Dialog mode inspired by Xiaozhi (xiaozhi-esp32)
-->
<screen permanent="true">
    <styles>
        <!-- ====== Top Bar Styles ====== -->
        <style name="style_top_bar"
            bg_color="0xffffff"
            bg_opa="100%"
            width="100%"
            height="36"
            pad_hor="#unit_md"
        />
        <style name="style_top_bar_dark"
            bg_color="0x16213e"
        />

        <!-- Icon button (transparent, for top bar actions) -->
        <style name="style_icon_btn"
            bg_opa="0%"
            radius="1000"
            pad_all="#unit_sm"
            width="32"
            height="32"
            text_color="0x9ca3af"
            text_font="font_16"
        />
        <style name="style_icon_btn_dark"
            text_color="0xd1d5db"
        />

        <!-- Top bar title -->
        <style name="style_topbar_title"
            text_font="font_14"
            text_color="0x374151"
        />
        <style name="style_topbar_title_dark"
            text_color="0xf9fafb"
        />

        <!-- ====== Face Area Styles ====== -->
        <!-- Face background circle with glow outline -->
        <style name="style_face_bg"
            bg_color="0xffffff"
            bg_opa="100%"
            radius="1000"
            width="160"
            height="160"
            border_color="0xe5e7eb"
            border_width="2"
            border_opa="100%"
            outline_width="6"
            outline_color="0x3b82f6"
            outline_opa="15%"
            outline_pad="4"
            shadow_width="20"
            shadow_offset_y="6"
            shadow_opa="12%"
            shadow_color="0x000000"
        />
        <style name="style_face_bg_dark"
            bg_color="0x1e293b"
            border_color="0x334155"
            outline_color="0x60a5fa"
            outline_opa="20%"
            shadow_opa="25%"
        />

        <!-- Eye style -->
        <style name="style_eye"
            bg_color="0x1e293b"
            bg_opa="100%"
            radius="1000"
            width="16"
            height="16"
        />
        <style name="style_eye_dark"
            bg_color="0xf1f5f9"
        />

        <!-- Eye pupil / highlight -->
        <style name="style_eye_pupil"
            bg_color="0xffffff"
            bg_opa="100%"
            radius="1000"
            width="5"
            height="5"
        />
        <style name="style_eye_pupil_dark"
            bg_color="0x94a3b8"
        />

        <!-- ====== Mouth Styles ====== -->
        <!-- Neutral: flat line -->
        <style name="style_mouth_neutral"
            bg_color="0x475569"
            bg_opa="100%"
            radius="4"
            width="44"
            height="6"
        />
        <style name="style_mouth_neutral_dark"
            bg_color="0xcbd5e1"
        />

        <!-- Happy: upward smile arc (bottom half of circle border) -->
        <style name="style_mouth_happy"
            bg_opa="0%"
            radius="1000"
            width="56"
            height="28"
            border_color="0x475569"
            border_width="4"
            border_opa="100%"
            border_side="bottom"
        />
        <style name="style_mouth_happy_dark"
            border_color="0xcbd5e1"
        />

        <!-- Sad: downward frown arc (top half of circle border) -->
        <style name="style_mouth_sad"
            bg_opa="0%"
            radius="1000"
            width="56"
            height="28"
            border_color="0x475569"
            border_width="4"
            border_opa="100%"
            border_side="top"
        />
        <style name="style_mouth_sad_dark"
            border_color="0xcbd5e1"
        />

        <!-- Thinking: small offset dot -->
        <style name="style_mouth_thinking"
            bg_color="0x475569"
            bg_opa="100%"
            radius="1000"
            width="13"
            height="13"
        />
        <style name="style_mouth_thinking_dark"
            bg_color="0xcbd5e1"
        />

        <!-- Speaking: medium open circle -->
        <style name="style_mouth_speaking"
            bg_color="0x475569"
            bg_opa="100%"
            radius="1000"
            width="26"
            height="26"
        />
        <style name="style_mouth_speaking_dark"
            bg_color="0xcbd5e1"
        />

        <!-- Surprised: large open circle -->
        <style name="style_mouth_surprised"
            bg_color="0x475569"
            bg_opa="100%"
            radius="1000"
            width="36"
            height="36"
        />
        <style name="style_mouth_surprised_dark"
            bg_color="0xcbd5e1"
        />

        <!-- Listening: small horizontal pill -->
        <style name="style_mouth_listening"
            bg_color="0x475569"
            bg_opa="100%"
            radius="4"
            width="32"
            height="6"
        />
        <style name="style_mouth_listening_dark"
            bg_color="0xcbd5e1"
        />

        <!-- ====== Status Area ====== -->
        <!-- Listening indicator dot -->
        <style name="style_listen_dot"
            bg_color="0x3b82f6"
            bg_opa="100%"
            radius="1000"
            width="8"
            height="8"
        />

        <style name="style_status_text"
            text_font="font_12"
            text_color="0x94a3b8"
            text_align="center"
        />
        <style name="style_status_text_dark"
            text_color="0x64748b"
        />

        <!-- ====== Dialog Mode Styles ====== -->
        <style name="style_dialog_top_bar"
            bg_color="0xffffff"
            bg_opa="100%"
            width="100%"
            height="36"
            pad_hor="#unit_md"
            border_side="bottom"
            border_color="0xe5e7eb"
            border_width="1"
        />
        <style name="style_dialog_top_bar_dark"
            bg_color="0x16213e"
            border_color="0x374151"
        />

        <!-- Chat scroll area -->
        <style name="style_chat_scroll"
            bg_color="0xf8fafc"
            bg_opa="100%"
            width="100%"
            pad_hor="#unit_sm"
            pad_ver="#unit_sm"
        />
        <style name="style_chat_scroll_dark"
            bg_color="0x0f172a"
        />

        <!-- User bubble (right-aligned, accent color) -->
        <style name="style_bubble_user"
            bg_color="0x3b82f6"
            bg_opa="100%"
            text_color="0xffffff"
            radius="#unit_md"
            pad_hor="#unit_md"
            pad_ver="#unit_sm"
            max_width="170"
            shadow_width="4"
            shadow_offset_y="2"
            shadow_opa="15%"
        />

        <!-- AI bubble (left-aligned, subtle) -->
        <style name="style_bubble_ai"
            bg_color="0xf1f5f9"
            bg_opa="100%"
            text_color="0x1e293b"
            radius="#unit_md"
            pad_hor="#unit_md"
            pad_ver="#unit_sm"
            max_width="170"
            border_color="0xe2e8f0"
            border_width="1"
        />
        <style name="style_bubble_ai_dark"
            bg_color="0x1e293b"
            text_color="0xf1f5f9"
            border_color="0x334155"
        />

        <!-- Empty state -->
        <style name="style_empty_hint"
            text_font="font_14"
            text_color="0x94a3b8"
            text_align="center"
        />
        <style name="style_empty_hint_dark"
            text_color="0x64748b"
        />
    </styles>

    <view flex_flow="column" width="100%" height="100%">
        <!-- Bind screen background -->
        <style name="style_screen_light" />
        <bind_style name="style_screen_dark" subject="dark_theme" ref_value="1" />

        <!-- ================================================================ -->
        <!-- EXPRESSION MODE (ai_mode = 0)                                   -->
        <!-- ================================================================ -->
        <lv_obj name="expression_mode_view" flex_flow="column" width="100%" height="100%">
            <bind_flag_if_eq subject="ai_mode" ref_value="1" flag="hidden" />

            <!-- Top bar with title and action buttons -->
            <lv_obj flex_flow="row" width="100%" style_flex_main_place="space_between" style_flex_cross_place="center">
                <style name="style_top_bar" />
                <bind_style name="style_top_bar_dark" subject="dark_theme" ref_value="1" />

                <!-- Title -->
                <lv_label text="AI Assistant">
                    <style name="style_topbar_title" />
                    <bind_style name="style_topbar_title_dark" subject="dark_theme" ref_value="1" />
                </lv_label>

                <!-- Action buttons -->
                <lv_obj flex_flow="row" style_flex_cross_place="center" style_pad_column="#unit_xs">
                    <!-- Music -->
                    <lv_button>
                        <style name="style_icon_btn" />
                        <bind_style name="style_icon_btn_dark" subject="dark_theme" ref_value="1" />
                        <lv_label text="♪" style_text_font="font_16" style_text_color="0x9ca3af" />
                        <screen_create_event screen="screen_music" anim_type="move_left" duration="300" />
                    </lv_button>

                    <!-- Settings -->
                    <lv_button>
                        <style name="style_icon_btn" />
                        <bind_style name="style_icon_btn_dark" subject="dark_theme" ref_value="1" />
                        <lv_label text="⚙" style_text_font="font_16" style_text_color="0x9ca3af" />
                        <screen_load_event screen="screen_settings" anim_type="move_left" duration="300" />
                    </lv_button>
                </lv_obj>
            </lv_obj>

            <!-- Face area (centered, flex_grow fills available space) -->
            <lv_obj name="face_container" flex_flow="column" flex_grow="1" style_flex_main_place="center" style_flex_cross_place="center" style_flex_track_place="center">
                <!-- Face background circle -->
                <lv_obj name="face_bg">
                    <style name="style_face_bg" />
                    <bind_style name="style_face_bg_dark" subject="dark_theme" ref_value="1" />

                    <!-- Left eye + pupil -->
                    <lv_obj name="eye_left" align="center" x="-32" y="-28">
                        <style name="style_eye" />
                        <bind_style name="style_eye_dark" subject="dark_theme" ref_value="1" />
                        <!-- Pupil highlight -->
                        <lv_obj align="center" x="2" y="-2">
                            <style name="style_eye_pupil" />
                            <bind_style name="style_eye_pupil_dark" subject="dark_theme" ref_value="1" />
                        </lv_obj>
                    </lv_obj>

                    <!-- Right eye + pupil -->
                    <lv_obj name="eye_right" align="center" x="32" y="-28">
                        <style name="style_eye" />
                        <bind_style name="style_eye_dark" subject="dark_theme" ref_value="1" />
                        <!-- Pupil highlight -->
                        <lv_obj align="center" x="2" y="-2">
                            <style name="style_eye_pupil" />
                            <bind_style name="style_eye_pupil_dark" subject="dark_theme" ref_value="1" />
                        </lv_obj>
                    </lv_obj>

                    <!-- ====== Mouth Variants ====== -->
                    <!-- C code manages show/hide based on expression subject -->

                    <!-- Neutral (expression=0) - default -->
                    <lv_obj name="mouth_neutral" align="center" y="24">
                        <style name="style_mouth_neutral" />
                        <bind_style name="style_mouth_neutral_dark" subject="dark_theme" ref_value="1" />
                    </lv_obj>

                    <!-- Happy (expression=1) -->
                    <lv_obj name="mouth_happy" align="center" y="20" hidden="true">
                        <style name="style_mouth_happy" />
                        <bind_style name="style_mouth_happy_dark" subject="dark_theme" ref_value="1" />
                    </lv_obj>

                    <!-- Sad (expression=2) -->
                    <lv_obj name="mouth_sad" align="center" y="20" hidden="true">
                        <style name="style_mouth_sad" />
                        <bind_style name="style_mouth_sad_dark" subject="dark_theme" ref_value="1" />
                    </lv_obj>

                    <!-- Thinking (expression=3) -->
                    <lv_obj name="mouth_thinking" align="center" x="8" y="26" hidden="true">
                        <style name="style_mouth_thinking" />
                        <bind_style name="style_mouth_thinking_dark" subject="dark_theme" ref_value="1" />
                    </lv_obj>

                    <!-- Speaking (expression=4) -->
                    <lv_obj name="mouth_speaking" align="center" y="26" hidden="true">
                        <style name="style_mouth_speaking" />
                        <bind_style name="style_mouth_speaking_dark" subject="dark_theme" ref_value="1" />
                    </lv_obj>

                    <!-- Surprised (expression=5) -->
                    <lv_obj name="mouth_surprised" align="center" y="28" hidden="true">
                        <style name="style_mouth_surprised" />
                        <bind_style name="style_mouth_surprised_dark" subject="dark_theme" ref_value="1" />
                    </lv_obj>

                    <!-- Listening (expression=6) -->
                    <lv_obj name="mouth_listening" align="center" y="24" hidden="true">
                        <style name="style_mouth_listening" />
                        <bind_style name="style_mouth_listening_dark" subject="dark_theme" ref_value="1" />
                    </lv_obj>
                </lv_obj>
            </lv_obj>

            <!-- Status area -->
            <lv_obj width="100%" flex_flow="row" style_flex_main_place="center" style_flex_cross_place="center" style_pad_ver="#unit_md" style_pad_column="#unit_sm">
                <!-- Listening indicator dot -->
                <lv_obj name="listen_indicator">
                    <style name="style_listen_dot" />
                </lv_obj>
                <!-- Status text -->
                <lv_label
                    text="Tap to talk"
                    width="content"
                >
                    <style name="style_status_text" />
                    <bind_style name="style_status_text_dark" subject="dark_theme" ref_value="1" />
                </lv_label>
            </lv_obj>
        </lv_obj>

        <!-- ================================================================ -->
        <!-- DIALOG MODE (ai_mode = 1)                                       -->
        <!-- ================================================================ -->
        <lv_obj name="dialog_mode_view" flex_flow="column" width="100%" height="100%">
            <bind_flag_if_eq subject="ai_mode" ref_value="0" flag="hidden" />

            <!-- Top bar -->
            <lv_obj flex_flow="row" width="100%" style_flex_main_place="space_between" style_flex_cross_place="center">
                <style name="style_dialog_top_bar" />
                <bind_style name="style_dialog_top_bar_dark" subject="dark_theme" ref_value="1" />

                <lv_label text="Conversation">
                    <style name="style_topbar_title" />
                    <bind_style name="style_topbar_title_dark" subject="dark_theme" ref_value="1" />
                </lv_label>

                <!-- Action buttons -->
                <lv_obj flex_flow="row" style_flex_cross_place="center" style_pad_column="#unit_xs">
                    <lv_button>
                        <style name="style_icon_btn" />
                        <bind_style name="style_icon_btn_dark" subject="dark_theme" ref_value="1" />
                        <lv_label text="♪" style_text_font="font_16" style_text_color="0x9ca3af" />
                        <screen_create_event screen="screen_music" anim_type="move_left" duration="300" />
                    </lv_button>
                    <lv_button>
                        <style name="style_icon_btn" />
                        <bind_style name="style_icon_btn_dark" subject="dark_theme" ref_value="1" />
                        <lv_label text="⚙" style_text_font="font_16" style_text_color="0x9ca3af" />
                        <screen_load_event screen="screen_settings" anim_type="move_left" duration="300" />
                    </lv_button>
                </lv_obj>
            </lv_obj>

            <!-- Scrollable chat area (messages populated by C code at runtime) -->
            <!--
                C code should dynamically create chat bubbles as children of
                this container. Each bubble is a row with:
                - AI messages: left-aligned, gray bg, rounded corners (top-left less rounded)
                - User messages: right-aligned, blue bg, rounded corners (top-right less rounded)
                Max 25 messages visible; older messages scroll off top.

                Use subject "ai_mode" changes to trigger a full refresh.
            -->
            <lv_obj
                name="chat_container"
                flex_grow="1"
                flex_flow="column"
                scrollable="true"
                style_pad_all="#unit_sm"
                style_pad_row="#unit_sm"
            >
                <style name="style_chat_scroll" />
                <bind_style name="style_chat_scroll_dark" subject="dark_theme" ref_value="1" />

                <!-- Placeholder hint (hidden once messages exist) -->
                <!-- C code should show/hide this based on message count -->
                <lv_label
                    name="chat_empty_hint"
                    text="No messages yet.&#10;Start a conversation!"
                    width="100%"
                    align="center"
                >
                    <style name="style_empty_hint" />
                    <bind_style name="style_empty_hint_dark" subject="dark_theme" ref_value="1" />
                </lv_label>

                <!--
                    Chat messages are added here at runtime by C code.
                    Example message bubbles (for reference):

                    AI message:
                    <view flex_flow="row" width="100%" style_flex_main_place="start">
                        <lv_label text="Hello! How can I help?" max_width="170"
                            style="style_bubble_ai" style_text_font="font_12" />
                    </view>

                    User message:
                    <view flex_flow="row" width="100%" style_flex_main_place="end">
                        <lv_label text="What is the weather?" max_width="170"
                            style="style_bubble_user" style_text_font="font_12" />
                    </view>
                -->
            </lv_obj>
        </lv_obj>
    </view>
</screen>
