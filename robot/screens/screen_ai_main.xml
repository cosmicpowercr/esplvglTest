<!--
    AI Main Page (Permanent)
    240x240 screen with two modes:
    - Expression Mode (ai_mode=0): 160x160 animated face + emotion icons
    - Dialog Mode (ai_mode=1): scrollable chat bubble list
    Always stays in memory — state persists across page switches.
-->
<screen permanent="true">
    <styles>
        <style name="style_root"
            bg_color="#bg_screen" text_color="#text_primary"
            layout="flex" flex_flow="column"
            width="100%" height="100%"
        />
        <style name="style_flex_row_center"
            layout="flex" flex_flow="row"
            flex_cross_place="center"
        />
        <style name="style_flex_col_center"
            layout="flex" flex_flow="column"
            flex_cross_place="center" flex_main_place="center"
        />
        <style name="style_status_bar"
            bg_opa="0"
            width="100%" height="32"
            pad_hor="#unit_md"
        />
        <style name="style_core_area"
            bg_opa="0"
            width="100%"
            flex_grow="1"
        />
        <style name="style_bottom_area"
            bg_opa="0"
            width="100%" height="56"
            pad_hor="#unit_md"
            pad_bottom="#unit_sm"
        />
        <style name="style_chat_scroll"
            bg_opa="0"
            width="100%"
            flex_grow="1"
            pad_hor="#unit_sm" pad_ver="#unit_xs"
        />
    </styles>

    <view>
        <style name="style_root" />

        <!-- ====== Top Status Bar (32px) ====== -->
        <lv_obj name="status_bar" style_flex_main_place="space_between">
            <style name="style_status_bar" />
            <style name="style_flex_row_center" />

            <!-- Left: Volume icon + value -->
            <lv_obj style_flex_flow="row" style_layout="flex" style_flex_cross_place="center"
                    style_pad_column="#unit_xs">
                <lv_label text="🔊" style_text_font="font_12" />
                <lv_label
                    bind_text="volume"
                    bind_text-fmt="%d%%"
                    style_text_font="font_12"
                    style_text_color="#text_primary"
                />
            </lv_obj>

            <!-- Right: WiFi icon + Time -->
            <lv_obj style_flex_flow="row" style_layout="flex" style_flex_cross_place="center"
                    style_pad_column="#unit_xs">
                <lv_label text="📶" style_text_font="font_12" />
                <lv_label
                    name="clock_label"
                    text="10:30"
                    style_text_font="font_12"
                    style_text_color="#text_primary"
                />
            </lv_obj>
        </lv_obj>

        <!-- ====== Core Display Area ====== -->
        <lv_obj name="core_area">
            <style name="style_core_area" />
            <style name="style_flex_col_center" />

            <!-- ====== Expression Mode (visible when ai_mode=0) ====== -->
            <lv_obj name="expr_mode" width="100%" flex_grow="1">
                <style name="style_flex_col_center" />
                <bind_flag_if_eq subject="ai_mode" flag="hidden" ref_value="1" />

                <!-- 160x160 face canvas area (C code draws via display_iface->draw_bitmap) -->
                <lv_obj name="face_container" width="160" height="160"
                    style_bg_opa="0" style_border_width="0">
                </lv_obj>

                <!-- Animation icon area (below face) -->
                <lv_obj style_flex_flow="row" style_layout="flex" style_flex_cross_place="center"
                        style_pad_column="#unit_sm" height="20" style_pad_top="#unit_sm">
                    <lv_image src="icon_heart" width="14" height="14" style_image_opa="80%" />
                    <lv_image src="icon_cloudy" width="14" height="14" style_image_opa="80%" />
                    <lv_image src="icon_sunny" width="14" height="14" style_image_opa="80%" />
                </lv_obj>
            </lv_obj>

            <!-- ====== Dialog Mode (visible when ai_mode=1) ====== -->
            <lv_obj name="dialog_mode" width="100%" flex_grow="1">
                <style name="style_flex_col_center" />
                <bind_flag_if_eq subject="ai_mode" flag="hidden" ref_value="0" />

                <!-- Scrollable chat message container -->
                <lv_obj name="chat_container" scrollable="true"
                        scroll_momentum="true" scroll_elastic="true">
                    <style name="style_chat_scroll" />
                    <style name="style_flex_col_center" />
                    <!-- Chat bubbles are created dynamically by C code (max 25 messages) -->
                </lv_obj>
            </lv_obj>
        </lv_obj>

        <!-- ====== Bottom Area (~56px) ====== -->
        <lv_obj name="bottom_area" style_flex_flow="column" style_layout="flex">
            <style name="style_bottom_area" />

            <!-- Status text + Waveform row -->
            <lv_obj style_flex_flow="row" style_layout="flex"
                    style_flex_main_place="space_between" style_flex_cross_place="center"
                    flex_grow="1" pad_hor="#unit_md">
                <!-- Left: Status text (C code updates via lv_label_set_text) -->
                <lv_label
                    name="status_text"
                    text="🎤 我在听..."
                    style_text_font="font_12"
                    style_text_color="#text_secondary"
                />

                <!-- Right: Waveform bars (animated by C code) -->
                <lv_obj style_flex_flow="row" style_layout="flex"
                        style_flex_cross_place="center" style_pad_column="2">
                    <lv_obj style_bg_color="#accent_primary" style_bg_opa="60%"
                            width="3" height="8" style_radius="1" />
                    <lv_obj style_bg_color="#accent_primary" style_bg_opa="80%"
                            width="3" height="14" style_radius="1" />
                    <lv_obj style_bg_color="#accent_primary" style_bg_opa="100%"
                            width="3" height="20" style_radius="1" />
                    <lv_obj style_bg_color="#accent_primary" style_bg_opa="80%"
                            width="3" height="14" style_radius="1" />
                    <lv_obj style_bg_color="#accent_primary" style_bg_opa="60%"
                            width="3" height="8" style_radius="1" />
                </lv_obj>
            </lv_obj>

            <!-- 3 Page indicator dots (centered) -->
            <lv_obj style_flex_flow="row" style_layout="flex"
                    style_flex_main_place="center" style_flex_cross_place="center"
                    style_pad_column="#unit_sm" height="10">
                <lv_obj width="6" height="6" style_radius="3"
                    style_bg_color="#accent_primary" style_bg_opa="100%" />
                <lv_obj width="6" height="6" style_radius="3"
                    style_bg_color="#text_secondary" style_bg_opa="100%" />
                <lv_obj width="6" height="6" style_radius="3"
                    style_bg_color="#text_secondary" style_bg_opa="100%" />
            </lv_obj>
        </lv_obj>
    </view>
</screen>
