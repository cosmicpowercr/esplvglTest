<!--
    Settings Page
    =============
    A long scrollable container page. Scroll down to see all settings
    including the WiFi QR code at the bottom.

    Sections:
      1. Volume — slider control (LV_SYMBOL_VOLUME_MID / LV_SYMBOL_VOLUME_MAX)
      2. AI Mode — toggle button between Expression mode and Dialog mode
                    (LV_SYMBOL_IMAGE for expression, LV_SYMBOL_LIST for dialog)
      3. Brightness — slider control (LV_SYMBOL_SETTINGS sun icon)
      4. WiFi — toggle button (LV_SYMBOL_WIFI)
      5. QR Code — for WiFi provisioning (lv_qrcode widget at the bottom)
-->
<screen>
    <styles>
        <!-- Top bar -->
        <style name="style_top_bar"
            bg_color="0xffffff"
            bg_opa="100%"
            width="100%"
            height="36"
            pad_hor="#unit_md"
        />
        <style name="style_top_bar_dark"
            bg_color="0x16213e"
        />

        <!-- Back button -->
        <style name="style_back_btn"
            bg_opa="0%"
            radius="#unit_md"
            pad_all="#unit_sm"
            width="32"
            height="32"
        />

        <!-- Section container -->
        <style name="style_section"
            bg_color="0xffffff"
            bg_opa="100%"
            width="100%"
            pad_hor="#unit_md"
            pad_ver="#unit_sm"
            radius="#unit_sm"
        />
        <style name="style_section_dark"
            bg_color="0x16213e"
        />

        <!-- Section title -->
        <style name="style_section_title"
            text_font="font_14"
            text_color="0x374151"
        />
        <style name="style_section_title_dark"
            text_color="0xf9fafb"
        />

        <!-- Section subtitle -->
        <style name="style_section_subtitle"
            text_font="font_10"
            text_color="0x9ca3af"
        />
        <style name="style_section_subtitle_dark"
            text_color="0x6b7280"
        />

        <!-- Value label -->
        <style name="style_value_label"
            text_font="font_16"
            text_color="0x3b82f6"
            text_align="center"
        />
        <style name="style_value_label_dark"
            text_color="0x60a5fa"
        />

        <!-- Slider styles -->
        <style name="style_slider_main"
            bg_color="0xd1d5db"
            bg_opa="100%"
            radius="20"
            height="6"
            width="100%"
        />
        <style name="style_slider_main_dark"
            bg_color="0x4b5563"
        />
        <style name="style_slider_indicator"
            bg_color="0x3b82f6"
            bg_opa="100%"
            radius="20"
        />
        <style name="style_slider_knob"
            bg_color="0xffffff"
            bg_opa="100%"
            pad_all="8"
            radius="20"
            border_color="0x3b82f6"
            border_width="2"
            shadow_width="4"
            shadow_offset_y="2"
            shadow_opa="20%"
        />
        <style name="style_slider_knob_dark"
            bg_color="0x1f2937"
            border_color="0x60a5fa"
        />

        <!-- Toggle button style -->
        <style name="style_toggle_btn"
            bg_color="0xf3f4f6"
            bg_opa="100%"
            radius="#unit_md"
            pad_hor="#unit_lg"
            pad_ver="#unit_sm"
            width="content"
            height="content"
            border_color="0xd1d5db"
            border_width="1"
        />
        <style name="style_toggle_btn_dark"
            bg_color="0x374151"
            border_color="0x4b5563"
        />

        <!-- Toggle button icon text -->
        <style name="style_toggle_icon"
            text_font="font_24"
            text_color="0x374151"
        />
        <style name="style_toggle_icon_dark"
            text_color="0xf9fafb"
        />

        <!-- Toggle button label -->
        <style name="style_toggle_label"
            text_font="font_12"
            text_color="0x374151"
        />
        <style name="style_toggle_label_dark"
            text_color="0xf9fafb"
        />

        <!-- QR code area -->
        <style name="style_qr_section"
            bg_color="0xffffff"
            bg_opa="100%"
            width="100%"
            pad_all="#unit_md"
            radius="#unit_sm"
        />
        <style name="style_qr_section_dark"
            bg_color="0x16213e"
        />

        <style name="style_qr_hint"
            text_font="font_10"
            text_color="0x9ca3af"
            text_align="center"
        />
        <style name="style_qr_hint_dark"
            text_color="0x6b7280"
        />
    </styles>

    <view flex_flow="column" width="100%" height="100%">
        <!-- Screen background -->
        <style name="style_screen_light" />
        <bind_style name="style_screen_dark" subject="dark_theme" ref_value="1" />

        <!-- ====== Top Navigation Bar ====== -->
        <lv_obj flex_flow="row" width="100%" style_flex_main_place="start" style_flex_cross_place="center">
            <style name="style_top_bar" />
            <bind_style name="style_top_bar_dark" subject="dark_theme" ref_value="1" />

            <!-- Back button (LV_SYMBOL_LEFT arrow) -->
            <lv_button>
                <style name="style_back_btn" />
                <lv_label text="←" style_text_font="font_16" style_text_color="0x374151">
                    <bind_style name="style_toggle_icon_dark" subject="dark_theme" ref_value="1" />
                </lv_label>
                <screen_load_event screen="screen_ai_main" anim_type="move_right" duration="300" />
            </lv_button>

            <lv_label text="Settings" style_text_font="font_16" style_text_color="0x374151" style_pad_left="#unit_sm">
                <bind_style name="style_section_title_dark" subject="dark_theme" ref_value="1" />
            </lv_label>
        </lv_obj>

        <!-- ====== Scrollable Settings Content ====== -->
        <lv_obj name="settings_scroll" flex_grow="1" flex_flow="column" scrollable="true"
            style_pad_all="#unit_md" style_pad_row="#unit_lg">

            <!-- ================================================================ -->
            <!-- 1. VOLUME SETTING                                                -->
            <!-- ================================================================ -->
            <lv_obj flex_flow="column" style_pad_row="#unit_sm">
                <style name="style_section" />
                <bind_style name="style_section_dark" subject="dark_theme" ref_value="1" />

                <!-- Section header row: icon + title + value -->
                <lv_obj flex_flow="row" width="100%" style_flex_main_place="space_between" style_flex_cross_place="center">
                    <lv_obj flex_flow="row" style_flex_cross_place="center" style_pad_column="#unit_sm">
                        <!-- Volume icon (LV_SYMBOL_VOLUME_MID) -->
                        <lv_label text="🔊" style_text_font="font_16" />

                        <lv_obj flex_flow="column">
                            <lv_label text="Volume">
                                <style name="style_section_title" />
                                <bind_style name="style_section_title_dark" subject="dark_theme" ref_value="1" />
                            </lv_label>
                            <lv_label text="Adjust speaker volume">
                                <style name="style_section_subtitle" />
                                <bind_style name="style_section_subtitle_dark" subject="dark_theme" ref_value="1" />
                            </lv_label>
                        </lv_obj>
                    </lv_obj>

                    <!-- Volume value display -->
                    <lv_label bind_text="volume" bind_text-fmt="%d%%">
                        <style name="style_value_label" />
                        <bind_style name="style_value_label_dark" subject="dark_theme" ref_value="1" />
                    </lv_label>
                </lv_obj>

                <!-- Volume slider -->
                <lv_slider bind_value="volume" min_value="0" max_value="100" width="100%" height="20">
                    <style name="style_slider_main" />
                    <style name="style_slider_indicator" selector="indicator" />
                    <style name="style_slider_knob" selector="knob" />
                    <bind_style name="style_slider_main_dark" subject="dark_theme" ref_value="1" />
                    <bind_style name="style_slider_knob_dark" subject="dark_theme" ref_value="1" selector="knob" />
                </lv_slider>
            </lv_obj>

            <!-- ================================================================ -->
            <!-- 2. AI MODE SWITCHING                                            -->
            <!-- ================================================================ -->
            <lv_obj flex_flow="column" style_pad_row="#unit_sm">
                <style name="style_section" />
                <bind_style name="style_section_dark" subject="dark_theme" ref_value="1" />

                <lv_obj flex_flow="row" width="100%" style_flex_main_place="space_between" style_flex_cross_place="center">
                    <lv_obj flex_flow="row" style_flex_cross_place="center" style_pad_column="#unit_sm">
                        <!-- Mode icon (changes based on current mode) -->
                        <lv_label text="🤖" style_text_font="font_16" />

                        <lv_obj flex_flow="column">
                            <lv_label text="AI Mode">
                                <style name="style_section_title" />
                                <bind_style name="style_section_title_dark" subject="dark_theme" ref_value="1" />
                            </lv_label>
                            <lv_label text="Expression or Dialog">
                                <style name="style_section_subtitle" />
                                <bind_style name="style_section_subtitle_dark" subject="dark_theme" ref_value="1" />
                            </lv_label>
                        </lv_obj>
                    </lv_obj>

                    <!-- Mode toggle button -->
                    <!-- ai_mode: 0=expression (😊), 1=dialog (💬) -->
                    <!-- C code handles the toggle: clicking flips ai_mode between 0 and 1 -->
                    <lv_button name="mode_toggle_btn">
                        <style name="style_toggle_btn" />
                        <bind_style name="style_toggle_btn_dark" subject="dark_theme" ref_value="1" />

                        <lv_obj flex_flow="row" style_flex_cross_place="center" style_pad_column="#unit_sm">
                            <!-- Expression mode icon (LV_SYMBOL_IMAGE equivalent: 😊) - shown when ai_mode=0 -->
                            <lv_label text="😊">
                                <style name="style_toggle_icon" />
                                <bind_style name="style_toggle_icon_dark" subject="dark_theme" ref_value="1" />
                                <bind_flag_if_eq subject="ai_mode" ref_value="1" flag="hidden" />
                            </lv_label>
                            <!-- Dialog mode icon (LV_SYMBOL_LIST equivalent: 💬) - shown when ai_mode=1 -->
                            <lv_label text="💬">
                                <style name="style_toggle_icon" />
                                <bind_style name="style_toggle_icon_dark" subject="dark_theme" ref_value="1" />
                                <bind_flag_if_eq subject="ai_mode" ref_value="0" flag="hidden" />
                            </lv_label>
                            <!-- Current mode text -->
                            <lv_label text="Expression" style_text_font="font_12">
                                <style name="style_toggle_label" />
                                <bind_style name="style_toggle_label_dark" subject="dark_theme" ref_value="1" />
                                <bind_flag_if_eq subject="ai_mode" ref_value="1" flag="hidden" />
                            </lv_label>
                            <lv_label text="Dialog" style_text_font="font_12">
                                <style name="style_toggle_label" />
                                <bind_style name="style_toggle_label_dark" subject="dark_theme" ref_value="1" />
                                <bind_flag_if_eq subject="ai_mode" ref_value="0" flag="hidden" />
                            </lv_label>
                        </lv_obj>
                        <!--
                            C code: on click, toggle ai_mode subject (0↔1).
                            When ai_mode changes, screen_ai_main (permanent) resets.
                            Use subject_set_int_event to toggle, or handle in C.
                        -->
                        <subject_set_int_event subject="ai_mode" value="1" trigger="clicked">
                        </subject_set_int_event>
                    </lv_button>
                </lv_obj>
            </lv_obj>

            <!-- ================================================================ -->
            <!-- 3. BRIGHTNESS SETTING                                           -->
            <!-- ================================================================ -->
            <lv_obj flex_flow="column" style_pad_row="#unit_sm">
                <style name="style_section" />
                <bind_style name="style_section_dark" subject="dark_theme" ref_value="1" />

                <lv_obj flex_flow="row" width="100%" style_flex_main_place="space_between" style_flex_cross_place="center">
                    <lv_obj flex_flow="row" style_flex_cross_place="center" style_pad_column="#unit_sm">
                        <!-- Brightness icon (LV_SYMBOL_SETTINGS sun) -->
                        <lv_label text="☀" style_text_font="font_16" />

                        <lv_obj flex_flow="column">
                            <lv_label text="Brightness">
                                <style name="style_section_title" />
                                <bind_style name="style_section_title_dark" subject="dark_theme" ref_value="1" />
                            </lv_label>
                            <lv_label text="Adjust screen brightness">
                                <style name="style_section_subtitle" />
                                <bind_style name="style_section_subtitle_dark" subject="dark_theme" ref_value="1" />
                            </lv_label>
                        </lv_obj>
                    </lv_obj>

                    <!-- Brightness value display -->
                    <lv_label bind_text="brightness" bind_text-fmt="%d%%">
                        <style name="style_value_label" />
                        <bind_style name="style_value_label_dark" subject="dark_theme" ref_value="1" />
                    </lv_label>
                </lv_obj>

                <!-- Brightness slider -->
                <lv_slider bind_value="brightness" min_value="0" max_value="100" width="100%" height="20">
                    <style name="style_slider_main" />
                    <style name="style_slider_indicator" selector="indicator" />
                    <style name="style_slider_knob" selector="knob" />
                    <bind_style name="style_slider_main_dark" subject="dark_theme" ref_value="1" />
                    <bind_style name="style_slider_knob_dark" subject="dark_theme" ref_value="1" selector="knob" />
                </lv_slider>
            </lv_obj>

            <!-- ================================================================ -->
            <!-- 4. WIFI SETTING                                                 -->
            <!-- ================================================================ -->
            <lv_obj flex_flow="column" style_pad_row="#unit_sm">
                <style name="style_section" />
                <bind_style name="style_section_dark" subject="dark_theme" ref_value="1" />

                <lv_obj flex_flow="row" width="100%" style_flex_main_place="space_between" style_flex_cross_place="center">
                    <lv_obj flex_flow="row" style_flex_cross_place="center" style_pad_column="#unit_sm">
                        <!-- WiFi icon (LV_SYMBOL_WIFI) -->
                        <lv_label text="📶" style_text_font="font_16" />

                        <lv_obj flex_flow="column">
                            <lv_label text="WiFi">
                                <style name="style_section_title" />
                                <bind_style name="style_section_title_dark" subject="dark_theme" ref_value="1" />
                            </lv_label>
                            <lv_label text="Enable or disable WiFi">
                                <style name="style_section_subtitle" />
                                <bind_style name="style_section_subtitle_dark" subject="dark_theme" ref_value="1" />
                            </lv_label>
                        </lv_obj>
                    </lv_obj>

                    <!-- WiFi toggle button -->
                    <!-- wifi_on: 0=OFF, 1=ON -->
                    <lv_button name="wifi_toggle_btn">
                        <style name="style_toggle_btn" />
                        <bind_style name="style_toggle_btn_dark" subject="dark_theme" ref_value="1" />

                        <lv_obj flex_flow="row" style_flex_cross_place="center" style_pad_column="#unit_sm">
                            <!-- OFF icon + text (shown when wifi_on=0) -->
                            <lv_label text="📶">
                                <style name="style_toggle_icon" />
                                <bind_style name="style_toggle_icon_dark" subject="dark_theme" ref_value="1" />
                                <bind_flag_if_eq subject="wifi_on" ref_value="1" flag="hidden" />
                            </lv_label>
                            <lv_label text="OFF" style_text_font="font_12" style_text_color="0xef4444">
                                <bind_flag_if_eq subject="wifi_on" ref_value="1" flag="hidden" />
                            </lv_label>
                            <!-- ON icon + text (shown when wifi_on=1) -->
                            <lv_label text="📶">
                                <style name="style_toggle_icon" />
                                <bind_style name="style_toggle_icon_dark" subject="dark_theme" ref_value="1" />
                                <bind_flag_if_eq subject="wifi_on" ref_value="0" flag="hidden" />
                            </lv_label>
                            <lv_label text="ON" style_text_font="font_12" style_text_color="0x10b981">
                                <bind_flag_if_eq subject="wifi_on" ref_value="0" flag="hidden" />
                            </lv_label>
                        </lv_obj>

                        <!-- C code: on click, toggle wifi_on subject (0↔1) -->
                        <subject_set_int_event subject="wifi_on" value="1" trigger="clicked" />
                    </lv_button>
                </lv_obj>
            </lv_obj>

            <!-- ================================================================ -->
            <!-- 5. QR CODE FOR WIFI PROVISIONING                                 -->
            <!-- ================================================================ -->
            <!--
                Reference: esp-brookesia framework WiFi provisioning pattern.
                The QR code encodes WiFi provisioning data (SSID, password, etc.)
                so users can scan it with a phone to configure WiFi.
                The C code should set the data dynamically based on config.
            -->
            <lv_obj flex_flow="column" name="qr_section" style_flex_cross_place="center" style_pad_row="#unit_md">
                <style name="style_qr_section" />
                <bind_style name="style_qr_section_dark" subject="dark_theme" ref_value="1" />

                <lv_label text="WiFi Provisioning" style_text_font="font_14" style_text_color="0x374151">
                    <bind_style name="style_section_title_dark" subject="dark_theme" ref_value="1" />
                </lv_label>
                <lv_label text="Scan QR code to connect" style_text_font="font_10">
                    <style name="style_qr_hint" />
                    <bind_style name="style_qr_hint_dark" subject="dark_theme" ref_value="1" />
                </lv_label>

                <!-- QR Code widget -->
                <!-- C code sets the "data" attribute with WiFi provisioning JSON/URL -->
                <!-- The data should be set at runtime based on device configuration -->
                <lv_qrcode
                    name="wifi_qrcode"
                    size="150"
                    dark_color="0x1f2937"
                    light_color="0xffffff"
                    quiet_zone="true"
                    data="https://espressif.com"
                />
                <!-- Note: C code should call lv_qrcode_set_data() to update
                     the QR code with actual WiFi provisioning information at runtime.
                     Reference the brookesia WiFi manager pattern. -->
            </lv_obj>

        </lv_obj>
    </view>
</screen>
