<!--
    Settings Page
    240x240 scrollable settings panel.
    - Fixed nav bar with Home button
    - Scrollable cards: Volume, Brightness, AI Mode, WiFi
    - QR code at bottom for WiFi provisioning
    Entry: Long press on AI Main Page
    Exit: Home button → AI Main Page, or swipe right → Music Page
-->
<screen>
    <styles>
        <style name="style_root"
            bg_color="#bg_screen" text_color="#text_primary"
            layout="flex" flex_flow="column"
            width="100%" height="100%"
        />
        <style name="style_flex_row_center"
            layout="flex" flex_flow="row"
            flex_cross_place="center"
        />
        <style name="style_content_scroll"
            bg_opa="0"
            width="100%"
            flex_grow="1"
            pad_hor="11" pad_ver="#unit_md"
        />
        <style name="style_card_row"
            layout="flex" flex_flow="row"
            flex_cross_place="center"
            flex_main_place="space_between"
            bg_color="#bg_card" bg_opa="100%"
            radius="12"
            pad_all="#unit_md"
            width="218" height="90"
        />
        <style name="style_icon_circle"
            bg_color="#bg_slider_track" bg_opa="30%"
            width="40" height="40" radius="20"
        />
        <style name="style_card_label"
            text_font="font_14"
            text_color="#text_primary"
        />
        <style name="style_card_sub"
            text_font="font_12"
            text_color="#text_secondary"
        />
    </styles>

    <view>
        <style name="style_root" />

        <!-- ====== Fixed Top Nav Bar (48px) ====== -->
        <lv_obj name="nav_bar">
            <style name="style_nav_bar" />
            <style name="style_flex_row_center" />

            <!-- Home button -->
            <lv_button width="44" height="44" style_bg_opa="0" style_border_width="0" style_radius="8">
                <lv_label text="⌂" style_text_font="font_20" style_text_color="#text_primary"
                    align="center" width="100%" />
                <screen_load_event screen="screen_ai_main" anim_type="none" />
            </lv_button>

            <!-- Title (centered, fills remaining space) -->
            <lv_label text="设置" style_text_font="font_16" style_text_color="#text_primary"
                flex_grow="1" style_text_align="center" />
        </lv_obj>

        <!-- ====== Scrollable Content Area ====== -->
        <lv_obj name="content_scroll" flex_flow="column" style_layout="flex" scrollable="true"
                scroll_momentum="true">
            <style name="style_content_scroll" />

            <!-- ====== Card 1: Volume ====== -->
            <lv_obj name="card_volume">
                <style name="style_card_row" />

                <!-- Music note icon (40x40 circle) -->
                <lv_obj>
                    <style name="style_icon_circle" />
                    <lv_label text="♪" style_text_font="font_16" style_text_color="#accent_primary"
                        align="center" width="100%" height="100%" />
                </lv_obj>

                <!-- Slider -->
                <lv_slider
                    bind_value="volume"
                    min_value="0" max_value="100"
                    width="110" height="24"
                    style_pad_hor="8"
                >
                    <style name="style_slider_main" selector="main" />
                    <style name="style_slider_indicator" selector="indicator" />
                    <style name="style_slider_knob" selector="knob" />
                </lv_slider>

                <!-- Value display -->
                <lv_label bind_text="volume" bind_text-fmt="%d%%"
                    style_text_font="font_14" style_text_color="#text_primary"
                    width="36" style_text_align="right" />
            </lv_obj>

            <!-- Spacer between cards -->
            <lv_obj height="10" style_bg_opa="0" />

            <!-- ====== Card 2: Brightness ====== -->
            <lv_obj name="card_brightness">
                <style name="style_card_row" />

                <!-- Sun icon (40x40 circle) -->
                <lv_obj>
                    <style name="style_icon_circle" />
                    <lv_label text="☀" style_text_font="font_16" style_text_color="#accent_primary"
                        align="center" width="100%" height="100%" />
                </lv_obj>

                <!-- Slider -->
                <lv_slider
                    bind_value="brightness"
                    min_value="0" max_value="100"
                    width="110" height="24"
                    style_pad_hor="8"
                >
                    <style name="style_slider_main" selector="main" />
                    <style name="style_slider_indicator" selector="indicator" />
                    <style name="style_slider_knob" selector="knob" />
                </lv_slider>

                <!-- Value display -->
                <lv_label bind_text="brightness" bind_text-fmt="%d%%"
                    style_text_font="font_14" style_text_color="#text_primary"
                    width="36" style_text_align="right" />
            </lv_obj>

            <!-- Spacer -->
            <lv_obj height="10" style_bg_opa="0" />

            <!-- ====== Card 3: AI Mode Switch ====== -->
            <lv_obj name="card_mode" clickable="true">
                <style name="style_card_row" />

                <!-- Mode icon -->
                <lv_obj>
                    <style name="style_icon_circle" />
                    <lv_label text="🔄" style_text_font="font_16" style_text_color="#accent_primary"
                        align="center" width="100%" height="100%" />
                </lv_obj>

                <!-- Mode text -->
                <lv_label
                    name="mode_label"
                    text="当前模式: 表情模式"
                    style_text_font="font_14"
                    style_text_color="#text_primary"
                />

                <!-- Right arrow -->
                <lv_label text="›" style_text_font="font_20" style_text_color="#text_secondary" />
                <!-- Click toggles ai_mode between 0 (expression) and 1 (dialog) -->
                <subject_toggle_event subject="ai_mode" trigger="clicked" />
            </lv_obj>

            <!-- Spacer -->
            <lv_obj height="10" style_bg_opa="0" />

            <!-- ====== Card 4: WiFi Settings ====== -->
            <lv_obj name="card_wifi">
                <style name="style_card_row" />

                <!-- WiFi icon (40x40 circle) -->
                <lv_obj>
                    <style name="style_icon_circle" />
                    <lv_label text="📶" style_text_font="font_16" style_text_color="#accent_primary"
                        align="center" width="100%" height="100%" />
                </lv_obj>

                <!-- WiFi info (column) -->
                <lv_obj flex_grow="1" style_pad_left="#unit_sm"
                        style_flex_flow="column" style_layout="flex" style_flex_cross_place="start">
                    <lv_label text="WiFi 设置" style_text_font="font_14" style_text_color="#text_primary" />
                    <lv_label text="已连接: Brookesia_2.4G" style_text_font="font_12" style_text_color="#text_secondary" />
                </lv_obj>

                <!-- Switch -->
                <lv_switch bind_checked="wifi_on" width="48" height="28">
                    <style name="style_switch_main" selector="main" />
                    <style name="style_switch_indicator_checked" selector="indicator|checked" />
                    <style name="style_switch_knob" selector="knob" />
                </lv_switch>
            </lv_obj>

            <!-- ====== QR Code Area (at bottom of scroll) ====== -->
            <lv_obj height="20" style_bg_opa="0" />

            <!-- 140x140 QR code (updated by C code at runtime) -->
            <lv_qrcode
                name="wifi_qrcode"
                size="140"
                dark_color="0xFFFFFF"
                light_color="0x0E121B"
                align="center"
            />

            <lv_obj height="#unit_sm" style_bg_opa="0" />

            <!-- QR hint text -->
            <lv_label
                text="使用 Brookesia APP 扫描连接 WiFi"
                align="center"
                style_text_font="font_12"
                style_text_color="#text_secondary"
                style_text_align="center"
                width="220"
            />

            <!-- Bottom padding for scroll -->
            <lv_obj height="#unit_md" style_bg_opa="0" />
        </lv_obj>
    </view>
</screen>
